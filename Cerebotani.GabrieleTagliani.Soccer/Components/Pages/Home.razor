@page "/"
@using Cerebotani.GabrieleTagliani.Soccer.Models
@namespace Cerebotani.GabrieleTagliani.Soccer.Components.Pages

<PageTitle>Soccer Stats - Home</PageTitle>

<RadzenText TextStyle="TextStyle.H3" class="rz-p-4 rz-text-align-center">Soccer Statistics Portal</RadzenText>

<div class="rz-p-12 rz-text-align-center" style="background-color: var(--rz-base-200); border-radius: 12px; max-width: 600px; margin: 0 auto;">
    <RadzenStack Gap="2rem" AlignItems="AlignItems.Center">
        
        <RadzenStack Gap="0.5rem">
            <RadzenText TextStyle="TextStyle.Overline">Stagione</RadzenText>
            <RadzenAutoComplete @bind-Value=@StagioneSelezionata
                                Data=@Stagioni 
                                Placeholder="Inserisci la stagione..." 
                                Style="width: 20rem" />
        </RadzenStack>

        <RadzenStack Gap="0.5rem">
            <RadzenText TextStyle="TextStyle.Overline">Campionato</RadzenText>
            <RadzenAutoComplete @bind-Value=@CampionatoSelezionato 
                                Data=@Campionati 
                                FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                                Placeholder="Inserisci il campionato..." 
                                Style="width: 20rem" />
        </RadzenStack>

        <RadzenButton Text="Vai alla classifica" 
                      Icon="leaderboard" 
                      Click="@Naviga" 
                      Disabled="@(string.IsNullOrEmpty(CampionatoSelezionato))" 
                      ButtonStyle="ButtonStyle.Primary" 
                      class="rz-mt-4" />

    </RadzenStack>
</div>