@page "/campionati-cechi"
@inject NavigationManager NavigationManager

<RadzenText TextStyle="TextStyle.H4" TagName="TagName.H1" class="rz-p-4">Campionati Cechi</RadzenText>

<RadzenRow class="rz-p-4">
    @* --- Chance Liga --- *@
    <RadzenColumn Size="12" SizeMD="4">
        <RadzenCard class="rz-my-4">
            <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.Start" Gap="1rem" class="rz-p-4">
                <RadzenImage Path="img/ChanceLigaLogo.jpg" Style="width: 80px; height: 80px;" />
                <RadzenStack Gap="0">
                    <RadzenText TextStyle="TextStyle.Overline" class="rz-display-flex rz-mt-2 rz-my-0">Lega Calcio</RadzenText>
                    <RadzenText TextStyle="TextStyle.H5"><b>Chance Liga</b></RadzenText>
                    <RadzenText TextStyle="TextStyle.Body2">Stagione 2025/2026</RadzenText>
                </RadzenStack>
            </RadzenStack>

            <RadzenCard class="rz-background-color-primary-light rz-shadow-0 rz-border-radius-0 rz-p-4" style="margin: 1rem calc(-1 * var(--rz-card-padding));">
                <RadzenRow>
                    <RadzenColumn Size="6">
                        <RadzenText TextStyle="TextStyle.Overline" class="rz-color-on-primary-light rz-mb-0">Squadre</RadzenText>
                        <RadzenText TextStyle="TextStyle.Body1" class="rz-color-on-primary-light"><b>16</b></RadzenText>
                    </RadzenColumn>
                    <RadzenColumn Size="6">
                        <RadzenText TextStyle="TextStyle.Overline" class="rz-color-on-primary-light rz-mb-0">Girone</RadzenText>
                        <RadzenText TextStyle="TextStyle.Body1" class="rz-color-on-primary-light"><b>1</b></RadzenText>
                    </RadzenColumn>
                </RadzenRow>
            </RadzenCard>

            <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" Gap="1rem">
                <RadzenButton Variant="Variant.Text" Text="Calendario" Icon="calendar_month" />
                <RadzenButton Variant="Variant.Filled" Text="Classifica" Icon="leaderboard" Click="@(() => GoToClassifica("chance-liga-2526"))" />
            </RadzenStack>
        </RadzenCard>
    </RadzenColumn>

    @* --- Fotbalova Narodni Liga --- *@
    <RadzenColumn Size="12" SizeMD="4">
        <RadzenCard class="rz-my-4">
            <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.Start" Gap="1rem" class="rz-p-4">
                <RadzenImage Path="img/FotbalovaNarodniLigaLogo.jpg" Style="width: 80px; height: 80px;" />
                <RadzenStack Gap="0">
                    <RadzenText TextStyle="TextStyle.Overline" class="rz-display-flex rz-mt-2 rz-my-0">Lega Calcio</RadzenText>
                    <RadzenText TextStyle="TextStyle.H5"><b>Fotbalová Liga</b></RadzenText>
                    <RadzenText TextStyle="TextStyle.Body2">Stagione 2025/2026</RadzenText>
                </RadzenStack>
            </RadzenStack>

            <RadzenCard class="rz-background-color-primary-light rz-shadow-0 rz-border-radius-0 rz-p-4" style="margin: 1rem calc(-1 * var(--rz-card-padding));">
                <RadzenRow>
                    <RadzenColumn Size="6">
                        <RadzenText TextStyle="TextStyle.Overline" class="rz-color-on-primary-light rz-mb-0">Squadre</RadzenText>
                        <RadzenText TextStyle="TextStyle.Body1" class="rz-color-on-primary-light"><b>16</b></RadzenText>
                    </RadzenColumn>
                    <RadzenColumn Size="6">
                        <RadzenText TextStyle="TextStyle.Overline" class="rz-color-on-primary-light rz-mb-0">Girone</RadzenText>
                        <RadzenText TextStyle="TextStyle.Body1" class="rz-color-on-primary-light"><b>1</b></RadzenText>
                    </RadzenColumn>
                </RadzenRow>
            </RadzenCard>

            <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" Gap="1rem">
                <RadzenButton Variant="Variant.Text" Text="Calendario" Icon="calendar_month" />
                <RadzenButton Variant="Variant.Filled" Text="Classifica" Icon="leaderboard" Click="@(() => GoToClassifica("fotbalova-narodni-liga-2526"))" />
            </RadzenStack>
        </RadzenCard>
    </RadzenColumn>

    @* --- SERIE C --- *@
    @* <RadzenColumn Size="12" SizeMD="4">
        <RadzenCard class="rz-my-4">
            <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.Start" Gap="1rem" class="rz-p-4">
                <RadzenImage Path="img/SerieCLogo.png" Style="width: 80px; height: 80px;" />
                <RadzenStack Gap="0">
                    <RadzenText TextStyle="TextStyle.Overline" class="rz-display-flex rz-mt-2 rz-my-0">Lega Calcio</RadzenText>
                    <RadzenText TextStyle="TextStyle.H5"><b>Serie C</b></RadzenText>
                    <RadzenText TextStyle="TextStyle.Body2">Stagione 2025/2026</RadzenText>
                </RadzenStack>
            </RadzenStack>

            <RadzenCard class="rz-background-color-primary-light rz-shadow-0 rz-border-radius-0 rz-p-4" style="margin: 1rem calc(-1 * var(--rz-card-padding));">
                <RadzenRow>
                    <RadzenColumn Size="6">
                        <RadzenText TextStyle="TextStyle.Overline" class="rz-color-on-primary-light rz-mb-0">Squadre</RadzenText>
                        <RadzenText TextStyle="TextStyle.Body1" class="rz-color-on-primary-light"><b>59</b></RadzenText>
                    </RadzenColumn>
                    <RadzenColumn Size="6">
                         <RadzenText TextStyle="TextStyle.Overline" class="rz-color-on-primary-light rz-mb-0">Gironi</RadzenText>
                         <RadzenText TextStyle="TextStyle.Body1" class="rz-color-on-primary-light"><b>3</b></RadzenText>
                    </RadzenColumn>
                </RadzenRow>
            </RadzenCard>

            <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" Gap="1rem">
                <RadzenButton Variant="Variant.Text" Text="Calendario" Icon="calendar_month" />
                <RadzenButton Variant="Variant.Filled" Text="Classifica" Icon="leaderboard" Click="@(() => GoToClassifica("serie-c-2526"))" />
            </RadzenStack>
        </RadzenCard>
    </RadzenColumn> *@
</RadzenRow>

@code {
    void GoToClassifica(string campionato)
    {
        NavigationManager.NavigateTo($"/{campionato}");
    }
}