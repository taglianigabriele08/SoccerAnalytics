@using System.Text.RegularExpressions
<RadzenStack Gap="1.5rem" Class="rz-p-4">
    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.Center" Gap="2rem">
        <RadzenStack AlignItems="AlignItems.Center" Style="width: 150px;">
            <RadzenImage Path="@GetLogoPath(Match.SquadraCasa)" 
                Style="width: 80px; height: 80px; object-fit: contain;" />
            <RadzenText TextStyle="TextStyle.H6" Text="@Match.SquadraCasa" TextAlign="TextAlign.Center" />
        </RadzenStack>

        <RadzenStack AlignItems="AlignItems.Center">
            <RadzenText TextStyle="TextStyle.H2" Class="rz-m-0" Style="font-weight: bold;">
                @(Match.GolCasa?.ToString() ?? "-") : @(Match.GolTrasferta?.ToString() ?? "-")
            </RadzenText>
            <RadzenBadge Text="FINALE" BadgeStyle="BadgeStyle.Light" />
        </RadzenStack>

        <RadzenStack AlignItems="AlignItems.Center" Style="width: 150px;">
            <RadzenImage Path="@GetLogoPath(Match.SquadraTrasferta)" 
                Style="width: 80px; height: 80px; object-fit: contain;" />
            <RadzenText TextStyle="TextStyle.H6" Text="@Match.SquadraTrasferta" TextAlign="TextAlign.Center" />
        </RadzenStack>
    </RadzenStack>

    <hr style="border: none; border-top: 1px solid var(--rz-divider); margin: 0;" />

    @* Sezione Marcatori *@
    @if (Match.Marcatori != null && Match.Marcatori.Any())
    {
        <RadzenRow>
            <RadzenColumn Size="6">
                <RadzenStack Gap="0.5rem">
                    @foreach (var m in Match.Marcatori.Where(m => m.SquadraNome == Match.SquadraCasa    ))
                    {
                        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                            <RadzenIcon Icon="sports_soccer" Size="IconSize.Small" />
                            <RadzenText TextStyle="TextStyle.Body2">
                                @m.Nome (@m.Minuto' @(m.Recupero.HasValue ? $"+{m.Recupero}" : "")) @(m.Rigore ? "(R)" : "")
                            </RadzenText>
                        </RadzenStack>
                    }
                </RadzenStack>
            </RadzenColumn>
            <RadzenColumn Size="6">
                <RadzenStack Gap="0.5rem" AlignItems="AlignItems.End">
                    @foreach (var m in Match.Marcatori.Where(m => m.SquadraNome == Match.SquadraTrasferta))
                    {
                        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                            <RadzenText TextStyle="TextStyle.Body2">
                                @(m.Rigore ? "(R)" : "") @m.Nome (@m.Minuto' @(m.Recupero.HasValue ? $"+{m.Recupero}" : ""))
                            </RadzenText>
                            <RadzenIcon Icon="sports_soccer" Size="IconSize.Small" />
                        </RadzenStack>
                    }
                </RadzenStack>
            </RadzenColumn>
        </RadzenRow>
    }
</RadzenStack>

@code {
    [Parameter] public Partita Match { get; set; } = default!;

    private string GetLogoPath(string? squadra)
    {
        if (Match?.Campionato == null || string.IsNullOrEmpty(squadra)) 
            return "/img/logo/default.png";

        // Determiniamo il prefisso della cartella in base al campionato
        string prefisso = Match.Campionato.Descrizione switch
        {
            "Serie A" => "SAloghi",
            "Premier League" => "PLloghi",
            "La Liga" => "LLloghi",
            "Bundesliga" => "BLloghi",
            _ => "logo" // cartella di fallback
        };

        return $"/img/{prefisso}/{squadra}.png";
    }
}
