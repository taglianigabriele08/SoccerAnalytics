@page "/squadre"

<RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween" Class="rz-mb-4">
    <RadzenText TextStyle="TextStyle.H4" Text="Gestione Squadre" />

    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
        <RadzenAutoComplete Icon="delete" ShowClear="true" @bind-Value=@RicercaSquadra  Data="@NomiSquadre" Placeholder="Cerca una squadra"
                FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive" Change=@OnSearchChange Style="width: 20rem" />
        <RadzenButton Icon="refresh" ButtonStyle="ButtonStyle.Light" Click="@ResetFiltro" ToolTip="Mostra tutte" />
    </RadzenStack>

    <RadzenUpload ChooseText="Importa Info (JSON)" Icon="file_upload" Auto="true" Accept=".json" Change="@OnUploadInfo" 
                InputAttributes="@(new Dictionary<string,object>(){ { "aria-label", "select file" }})" />
    <RadzenButton ButtonStyle="ButtonStyle.Success" Icon="add_circle" Text="Nuova Squadra" Click="@InsertRow" />
    <RadzenButton ButtonStyle="ButtonStyle.Danger" Icon="delete" Text="Cancella Squadre" Click="@DeleteAll" />
</RadzenStack> 

<RadzenDataGrid @ref="grid" AllowFiltering="true" AllowPaging="true" PageSize="10" AllowSorting="true"
                Data="@Items" TItem="Squadra" RowSelect="@OpenDetails">
    <Columns>
        <RadzenDataGridColumn TItem="Squadra" Title="Logo" Width="80px" Sortable="false" Filterable="false" TextAlign="TextAlign.Center">
            <Template Context="squadra">
                <RadzenImage Path="@(string.IsNullOrEmpty(squadra.LogoUrl) ? "images/default-logo.png" : squadra.LogoUrl)" 
                            Style="width: 40px; height: 40px; border-radius: 8px; object-fit: contain;" 
                            AlternateText="Logo" />
            </Template>
        </RadzenDataGridColumn>

        <RadzenDataGridColumn TItem="Squadra" Property="Nome" Title="Nome Squadra" />
        <RadzenDataGridColumn TItem="Squadra" Property="Anno" Title="Anno di Fondazione" TextAlign="TextAlign.Center" />
        <RadzenDataGridColumn TItem="Squadra" Property="Citta" Title="Città" TextAlign="TextAlign.Center" />
        <RadzenDataGridColumn TItem="Squadra" Property="Stadio" Title="Stadio" TextAlign="TextAlign.Center" />

        <RadzenDataGridColumn TItem="Squadra" Context="squadra" Filterable="false" Sortable="false" TextAlign="TextAlign.Right" Width="80px">
            <Template Context="squadra">
                <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Variant="Variant.Flat" 
                            Size="ButtonSize.Medium" Click="@(args => ConfirmDelete(squadra))" 
                            @onclick:stopPropagation="true" />
            </Template>
        </RadzenDataGridColumn>
    </Columns>
</RadzenDataGrid>